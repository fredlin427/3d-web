generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Case {
  id                   String              @id @default(cuid())
  caseNumber           String              @unique @map("case_number")
  applicationDate      DateTime            @map("application_date")
  expectedCompletionDate DateTime?         @map("expected_completion_date")
  approvalDate         DateTime?           @map("approval_date")
  completionDate       DateTime?           @map("completion_date")
  ownership            String?
  department           String
  hospital             String              @default("QEH")
  applicantName        String              @map("applicant_name")
  contact              String?
  rank                 String?
  category             String              @map("category")
  purpose              String              @map("purpose")
  specification        String?
  projectTitle         String              @map("project_title")
  description          String?
  modelType            String?             @map("model_type")
  requiredService      String?             @map("required_service")
  serviceRequirements  String?             @map("service_requirements")
  requiresSterilization String?            @map("requires_sterilization")
  quantity             Int                 @default(1)
  totalComponents      Int                 @default(1) @map("total_components")
  priority             String              @default("Routine")
  currentStatus        String              @default("Draft") @map("current_status")
  currentProgressStep  String?             @map("current_progress_step")
  technician           String?
  printingParty        String?             @map("printing_party")
  modelImageUrl        String?             @map("model_image_url")
  photoFolderUrl       String?             @map("photo_folder_url")
  remarks              String?
  telephone            String?
  email                String?
  signature            String?
  signatureDate        DateTime?           @map("signature_date")
  modelMaterial        String?             @map("model_material")
  colourRequirement    String?             @map("colour_requirement")
  copyrightRisk        Boolean?            @map("copyright_risk")
  copyrightDetails     String?             @map("copyright_details")
  isReprint            Boolean?            @map("is_reprint")
  fundingSource        String?             @map("funding_source")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  progressSteps        CaseProgressStep[]
  materialUsage        CaseMaterialUsage[]
  stockTransactions    StockTransaction[]

  @@map("cases")
}

model CaseProgressStep {
  id            String    @id @default(cuid())
  caseId        String    @map("case_id")
  stepName      String    @map("step_name")
  stepOrder     Int       @map("step_order")
  status        String    @default("Not started")
  completedDate DateTime? @map("completed_date")
  staffName     String?   @map("staff_name")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  case          Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("case_progress_steps")
}

model Material {
  id               String               @id @default(cuid())
  category         String
  materialName     String               @map("material_name")
  brand            String?
  materialType     String?              @map("material_type")
  compatiblePrinter String?             @map("compatible_printer")
  colour           String?
  diameter         Float?               @map("diameter")
  volume           Float?               @map("volume")
  productCode      String?              @map("product_code")
  materialId       String?              @map("material_id")
  batchNumber      String               @map("batch_number")
  supplier         String?
  purchaseDate     DateTime?            @map("purchase_date")
  receivedDate     DateTime?            @map("received_date")
  openDate         DateTime?            @map("open_date")
  manufacturingDate DateTime?           @map("manufacturing_date")
  expiryDate       DateTime?            @map("expiry_date")
  disposalDate     DateTime?            @map("disposal_date")
  initialQuantity  Float                @map("initial_quantity")
  currentQuantity  Float                @map("current_quantity")
  unusedQuantity   Float                @default(0) @map("unused_quantity")
  openedQuantity   Float                @default(0) @map("opened_quantity")
  expiredQuantity  Float                @default(0) @map("expired_quantity")
  unit             String               @default("unit")
  reorderThreshold Float                @default(0) @map("reorder_threshold")
  storageLocation  String?              @map("storage_location")
  status           String               @default("In stock")
  remarks          String?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  materialUsage    CaseMaterialUsage[]
  stockTransactions StockTransaction[]

  @@index([batchNumber])
  @@index([category])
  @@map("materials")
}

model CaseMaterialUsage {
  id            String            @id @default(cuid())
  caseId        String            @map("case_id")
  materialId    String            @map("material_id")
  usageDate     DateTime          @map("usage_date")
  quantityUsed  Float             @map("quantity_used")
  unit          String            @default("unit")
  staffName     String?           @map("staff_name")
  printerOrTank String?           @map("printer_or_tank")
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  case          Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  material      Material          @relation(fields: [materialId], references: [id])

  @@index([caseId])
  @@index([materialId])
  @@map("case_material_usage")
}

model StockTransaction {
  id              String            @id @default(cuid())
  materialId      String            @map("material_id")
  transactionType String            @map("transaction_type")
  quantityChange  Float             @map("quantity_change")
  quantityAfter   Float             @map("quantity_after")
  relatedCaseId   String?           @map("related_case_id")
  transactionDate DateTime          @map("transaction_date")
  staffName       String?           @map("staff_name")
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  material        Material          @relation(fields: [materialId], references: [id])
  relatedCase     Case?             @relation(fields: [relatedCaseId], references: [id], onDelete: SetNull)

  @@index([materialId])
  @@index([relatedCaseId])
  @@map("stock_transactions")
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  details    String?
  staffName  String   @map("staff_name")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  id        String   @id @default(cuid())
  type      String
  value     String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
